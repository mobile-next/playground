<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Playground" parent="Theme.MaterialComponents.Light.NoActionBar" />

    <!--
      Light toolbar shared across screens: a surface-colored background with
      the light theme's default dark title and navigation icon.
    -->
    <style name="Widget.Playground.Toolbar" parent="Widget.MaterialComponents.Toolbar">
        <item name="android:background">?attr/colorSurface</item>
    </style>

    <style name="SectionHeader">
        <item name="android:textSize">13sp</item>
        <item name="android:textColor">#6C6C72</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:paddingTop">20dp</item>
        <item name="android:paddingBottom">6dp</item>
    </style>
</resources>
