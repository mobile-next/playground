<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="#1C1C1E"
            app:titleTextColor="#FFFFFF"
            app:navigationIconTint="#FFFFFF" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2F2F7"
    app:layout_behavior="@string/appbar_scrolling_view_behavior">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="32dp">

        <!-- Text Fields -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Text Fields"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <EditText
                android:id="@+id/text_field"
                android:contentDescription="text_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Text Field"
                android:inputType="text"
                android:padding="14dp"
                android:background="@null"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <EditText
                android:id="@+id/password_field"
                android:contentDescription="password_field"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Password"
                android:inputType="textPassword"
                android:padding="14dp"
                android:background="@null"
                android:textSize="16sp" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <EditText
                android:id="@+id/multiline_text"
                android:contentDescription="multiline_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Multiline text"
                android:inputType="textMultiLine"
                android:minLines="3"
                android:gravity="top|start"
                android:padding="14dp"
                android:background="@null"
                android:textSize="16sp" />
        </LinearLayout>

        <!-- Controls -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Controls"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Toggle"
                    android:textSize="16sp" />
                <Switch
                    android:id="@+id/toggle"
                    android:contentDescription="toggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <LinearLayout
                android:id="@+id/stepper"
                android:contentDescription="stepper"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Counter"
                    android:textSize="16sp" />
                <Button
                    android:id="@+id/stepper_decrement"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="−"
                    android:textSize="18sp"
                    android:padding="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
                <TextView
                    android:id="@+id/stepper_value"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:text="0"
                    android:textSize="16sp"
                    android:gravity="center" />
                <Button
                    android:id="@+id/stepper_increment"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:padding="0dp"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <Button
                android:id="@+id/button"
                android:contentDescription="button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Reset Counter"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

        <!-- Slider -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Slider"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp">
            <SeekBar
                android:id="@+id/slider"
                android:contentDescription="slider"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="100" />
            <TextView
                android:id="@+id/slider_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="0.00"
                android:textSize="14sp"
                android:textColor="#6C6C72" />
        </LinearLayout>

        <!-- Picker -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Picker"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Picker"
                    android:textSize="16sp" />
                <Spinner
                    android:id="@+id/picker"
                    android:contentDescription="picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Segmented Control"
                    android:textSize="14sp"
                    android:textColor="#6C6C72"
                    android:layout_marginBottom="4dp" />
                <RadioGroup
                    android:id="@+id/segmented_control"
                    android:contentDescription="segmented_control"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <RadioButton
                        android:id="@+id/seg_one"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="One"
                        android:checked="true" />
                    <RadioButton
                        android:id="@+id/seg_two"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Two"
                        android:layout_marginStart="16dp" />
                    <RadioButton
                        android:id="@+id/seg_three"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Three"
                        android:layout_marginStart="16dp" />
                </RadioGroup>
            </LinearLayout>
        </LinearLayout>

        <!-- Date -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Date"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Date"
                    android:textSize="16sp" />
                <Button
                    android:id="@+id/date_picker"
                    android:contentDescription="date_picker"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Select Date"
                    style="@style/Widget.MaterialComponents.Button.TextButton" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/date_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="No date selected"
                android:textSize="14sp"
                android:textColor="#6C6C72" />
        </LinearLayout>

        <!-- Progress -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Progress"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Progress View"
                    android:textSize="14sp"
                    android:textColor="#6C6C72"
                    android:layout_marginBottom="8dp" />
                <ProgressBar
                    android:id="@+id/progress_view"
                    android:contentDescription="progress_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/Widget.AppCompat.ProgressBar.Horizontal"
                    android:progress="50"
                    android:max="100" />
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:orientation="horizontal"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Activity Indicator"
                    android:textSize="16sp" />
                <ProgressBar
                    android:id="@+id/activity_indicator"
                    android:contentDescription="activity_indicator"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
        </LinearLayout>

        <!-- Labels -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Labels"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <TextView
                android:id="@+id/label"
                android:contentDescription="label"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Label"
                android:textSize="16sp"
                android:drawableStart="@android:drawable/ic_dialog_info"
                android:drawablePadding="10dp"
                android:gravity="center_vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/plain_label"
                android:contentDescription="plain_label"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="Plain Label"
                android:textSize="16sp"
                android:gravity="center_vertical" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/link"
                android:contentDescription="link"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:text="mobilewright.dev"
                android:textSize="16sp"
                android:textColor="#007AFF"
                android:gravity="center_vertical"
                android:background="?attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

        <!-- Dialogs & Menus -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dialogs &amp; Menus"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <Button
                android:id="@+id/alert_button"
                android:contentDescription="alert_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Show Alert"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <Button
                android:id="@+id/confirmation_button"
                android:contentDescription="confirmation_button"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Confirmation Dialog"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <Button
                android:id="@+id/menu"
                android:contentDescription="menu"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Menu"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <TextView
                android:id="@+id/menu_last_action"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:paddingTop="12dp"
                android:paddingBottom="12dp"
                android:text="Last action: (none)"
                android:textSize="14sp"
                android:textColor="#6C6C72" />
        </LinearLayout>

        <!-- Share & Photos -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Share &amp; Photos"
            style="@style/SectionHeader" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#FFFFFF">

            <Button
                android:id="@+id/share_link"
                android:contentDescription="share_link"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Share"
                style="@style/Widget.MaterialComponents.Button.TextButton" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginStart="14dp"
                android:background="#E0E0E0" />

            <Button
                android:id="@+id/photos_picker"
                android:contentDescription="photos_picker"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Select Photo"
                style="@style/Widget.MaterialComponents.Button.TextButton" />
        </LinearLayout>

    </LinearLayout>
    </ScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
